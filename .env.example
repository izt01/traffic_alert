# =============================================
# 高速道路渋滞情報通知サービス 環境変数設定
# =============================================

# HERE Traffic API（リアルタイム渋滞情報）
# 取得先: https://developer.here.com/
# 無料枠: 月25万リクエスト（想定使用: 月約400req → 余裕で無料枠内）
# ※クレカ登録は必要ですが、無料枠内は課金されません
HERE_API_KEY=your_here_api_key_here

# SendGrid（メール送信）
# 取得先: https://sendgrid.com/
# ※無料枠は月100通のみ。月2日×4時間×30分毎=約16通/日 → 月32通で無料枠内 ✅
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=高速道路渋滞情報

# デフォルト送信先（管理画面のメールタブで登録した場合は不要）
TO_EMAILS=you@example.com

# Railway PostgreSQL（Railway管理画面で自動設定されます）
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 管理画面のパスワード（空欄=認証なし）
ADMIN_PASSWORD=your_admin_password

# タイムゾーン
TZ=Asia/Tokyo
